<mujoco model="leap_scene">
  <include file="leap_rh_touch_mjx.xml"/>

  <default>
    <default class="cube">
      <geom friction=".3 0.05" conaffinity="2" condim="3"/>
    </default>
  </default>

  <statistic center="0.15 0 0" extent="0.4" meansize="0.01"/>

  <visual>
    <headlight diffuse=".8 .8 .8" ambient=".2 .2 .2" specular="1 1 1"/>
    <rgba force="1 0 0 1"/>
    <global azimuth="120" elevation="-20"/>
    <map force="0.01" stiffness="500"/>
    <scale forcewidth="0.1" contactwidth="0.5" contactheight="0.2"/>
    <quality shadowsize="8192"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="800" height="800"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="1 1 1" rgb2="1 1 1" markrgb="0 0 0"
      width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0"/>
    
    <!-- Object materials -->
    <material name="cube_gray" rgba="0.7 0.7 0.7 1"/>
    <material name="pink" rgba="1.0 0.4 0.8 1.0"/>
    <material name="lightblue" rgba="0.6 0.8 1.0 1.0"/>
    <material name="lightgreen" rgba="0.6 1.0 0.6 1.0"/>
    <material name="lightyellow" rgba="1.0 1.0 0.6 1.0"/>
    <material name="lightpurple" rgba="0.8 0.6 1.0 1.0"/>
    <material name="salmon" rgba="1.0 0.6 0.5 1.0"/>
  </asset>

  <worldbody>
    <camera name="side" pos="-0.183 0.396 0.296" xyaxes="-0.783 -0.622 -0.000 0.332 -0.419 0.845"/>
    <geom name="floor" pos="0 0 -0.25" size="0 0 0.01" type="plane" material="groundplane" contype="2" conaffinity="2"/>
    
    <!-- Cube 0 - Original Cube -->
    <body name="cube0" pos="0.11 0.0 0.1" quat="1 0 0 0" childclass="cube">
      <freejoint name="cube0_freejoint"/>
      <geom name="cube0_geom" type="box" size=".035 .035 .035" mass=".036" material="cube_gray" contype="4" conaffinity="3" group="3"/>
      <site name="cube0_center" pos="0 0 0" group="4"/>
    </body>
    
    <!-- Cube 1 -->
    <body name="cube1" pos="0.11 0.0 0.1" quat="1 0 0 0" childclass="cube">
      <freejoint name="cube1_freejoint"/>
      <geom name="cube1_geom" type="box" size=".033333 .033333 .033333" mass=".031098" material="lightblue" contype="8" conaffinity="3" group="3"/>
      <site name="cube1_center" pos="0 0 0" group="4"/>
    </body>
    
    <!-- Cube 2 -->
    <body name="cube2" pos="0.11 0.0 0.1" quat="1 0 0 0" childclass="cube">
      <freejoint name="cube2_freejoint"/>
      <geom name="cube2_geom" type="box" size=".031667 .031667 .031667" mass=".026663" material="lightgreen" contype="16" conaffinity="3" group="3"/>
      <site name="cube2_center" pos="0 0 0" group="4"/>
    </body>
    
    <!-- Cube 3 -->
    <body name="cube3" pos="0.11 0.0 0.1" quat="1 0 0 0" childclass="cube">
      <freejoint name="cube3_freejoint"/>
      <geom name="cube3_geom" type="box" size=".03 .03 .03" mass=".022671" material="lightyellow" contype="32" conaffinity="3" group="3"/>
      <site name="cube3_center" pos="0 0 0" group="4"/>
    </body>
    
    <!-- Cube 4 -->
    <body name="cube4" pos="0.11 0.0 0.1" quat="1 0 0 0" childclass="cube">
      <freejoint name="cube4_freejoint"/>
      <geom name="cube4_geom" type="box" size=".028333 .028333 .028333" mass=".019098" material="lightpurple" contype="64" conaffinity="3" group="3"/>
      <site name="cube4_center" pos="0 0 0" group="4"/>
    </body>
    
    <!-- Cube 5 -->
    <body name="cube5" pos="0.11 0.0 0.1" quat="1 0 0 0" childclass="cube">
      <freejoint name="cube5_freejoint"/>
      <geom name="cube5_geom" type="box" size=".026667 .026667 .026667" mass=".015922" material="lightpurple" contype="128" conaffinity="3" group="3"/>
      <site name="cube5_center" pos="0 0 0" group="4"/>
    </body>
    
    <!-- Cube 6 -->
    <body name="cube6" pos="0.11 0.0 0.1" quat="1 0 0 0" childclass="cube">
      <freejoint name="cube6_freejoint"/>
      <geom name="cube6_geom" type="box" size=".025 .025 .025" mass=".01312" material="salmon" contype="256" conaffinity="3" group="3"/>
      <site name="cube6_center" pos="0 0 0" group="4"/>
    </body>
    
    <body name="goal" mocap="true" pos="0.325 0.17 0.0475">
      <geom type="box" size=".035 .035 .035" mass=".108" group="3"/>
    </body>
  </worldbody>

  <sensor>
    <!-- cube sensors for all objects -->
    <framepos name="cube0_position" objtype="body" objname="cube0"/>
    <framequat name="cube0_orientation" objtype="body" objname="cube0"/>
    <framelinvel name="cube0_linvel" objtype="body" objname="cube0"/>
    <frameangvel name="cube0_angvel" objtype="body" objname="cube0"/>
    <frameangacc name="cube0_angacc" objtype="body" objname="cube0"/>
    <framezaxis name="cube0_upvector" objtype="body" objname="cube0"/>
    
    <framepos name="cube1_position" objtype="body" objname="cube1"/>
    <framequat name="cube1_orientation" objtype="body" objname="cube1"/>
    <framelinvel name="cube1_linvel" objtype="body" objname="cube1"/>
    <frameangvel name="cube1_angvel" objtype="body" objname="cube1"/>
    <frameangacc name="cube1_angacc" objtype="body" objname="cube1"/>
    <framezaxis name="cube1_upvector" objtype="body" objname="cube1"/>
    
    <framepos name="cube2_position" objtype="body" objname="cube2"/>
    <framequat name="cube2_orientation" objtype="body" objname="cube2"/>
    <framelinvel name="cube2_linvel" objtype="body" objname="cube2"/>
    <frameangvel name="cube2_angvel" objtype="body" objname="cube2"/>
    <frameangacc name="cube2_angacc" objtype="body" objname="cube2"/>
    <framezaxis name="cube2_upvector" objtype="body" objname="cube2"/>
    
    <framepos name="cube3_position" objtype="body" objname="cube3"/>
    <framequat name="cube3_orientation" objtype="body" objname="cube3"/>
    <framelinvel name="cube3_linvel" objtype="body" objname="cube3"/>
    <frameangvel name="cube3_angvel" objtype="body" objname="cube3"/>
    <frameangacc name="cube3_angacc" objtype="body" objname="cube3"/>
    <framezaxis name="cube3_upvector" objtype="body" objname="cube3"/>
    
    <framepos name="cube4_position" objtype="body" objname="cube4"/>
    <framequat name="cube4_orientation" objtype="body" objname="cube4"/>
    <framelinvel name="cube4_linvel" objtype="body" objname="cube4"/>
    <frameangvel name="cube4_angvel" objtype="body" objname="cube4"/>
    <frameangacc name="cube4_angacc" objtype="body" objname="cube4"/>
    <framezaxis name="cube4_upvector" objtype="body" objname="cube4"/>
    
    <framepos name="cube5_position" objtype="body" objname="cube5"/>
    <framequat name="cube5_orientation" objtype="body" objname="cube5"/>
    <framelinvel name="cube5_linvel" objtype="body" objname="cube5"/>
    <frameangvel name="cube5_angvel" objtype="body" objname="cube5"/>
    <frameangacc name="cube5_angacc" objtype="body" objname="cube5"/>
    <framezaxis name="cube5_upvector" objtype="body" objname="cube5"/>
    
    <framepos name="cube6_position" objtype="body" objname="cube6"/>
    <framequat name="cube6_orientation" objtype="body" objname="cube6"/>
    <framelinvel name="cube6_linvel" objtype="body" objname="cube6"/>
    <frameangvel name="cube6_angvel" objtype="body" objname="cube6"/>
    <frameangacc name="cube6_angacc" objtype="body" objname="cube6"/>
    <framezaxis name="cube6_upvector" objtype="body" objname="cube6"/>

    <!-- hand. -->
    <framepos name="palm_position" objtype="site" objname="grasp_site"/>
    <framepos name="th_tip_position" objtype="site" objname="th_tip" reftype="site" refname="grasp_site"/>
    <framepos name="if_tip_position" objtype="site" objname="if_tip" reftype="site" refname="grasp_site"/>
    <framepos name="mf_tip_position" objtype="site" objname="mf_tip" reftype="site" refname="grasp_site"/>
    <framepos name="rf_tip_position" objtype="site" objname="rf_tip" reftype="site" refname="grasp_site"/>

    <!-- goal. -->
    <framequat name="cube_goal_orientation" objtype="body" objname="goal"/>
    <framezaxis name="cube_goal_upvector" objtype="body" objname="goal"/>
  </sensor>

  <keyframe>
    <key name="home"
      qpos="
      0.8 0 0.8 0.8
      0.8 0 0.8 0.8
      0.8 0 0.8 0.8
      0.8 0.8 0.8 0
      0.11 0.0 0.1 1 0 0 0
      0.11 0.0 0.1 1 0 0 0
      0.11 0.0 0.1 1 0 0 0
      0.11 0.0 0.1 1 0 0 0
      0.11 0.0 0.1 1 0 0 0
      0.11 0.0 0.1 1 0 0 0
      0.11 0.0 0.1 1 0 0 0"
      ctrl="
      0.8 0 0.8 0.8
      0.8 0 0.8 0.8
      0.8 0 0.8 0.8
      0.8 0.8 0.8 0" mpos="0.25 0.16 0"
      mquat="1 0 0 0"/>
  </keyframe>
</mujoco>
